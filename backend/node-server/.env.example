# ─── Required ─────────────────────────────────────────────────────────────────

MONGODB_URI=mongodb://localhost:27017/the-brain

# ─── LLM (Ollama default) ─────────────────────────────────────────────────────
# ollama pull llama3.2

LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=llama3.2
LLM_API_KEY=local

# ─── Embeddings (Ollama default) ──────────────────────────────────────────────
# ollama pull nomic-embed-text

EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
EMBEDDING_MODEL=nomic-embed-text

# ─── Optional ─────────────────────────────────────────────────────────────────

# User ID for CLI session (default: "default")
# BRAIN_USER_ID=your-name

# Override LLM timeout in ms (default: 120000)
# LLM_TIMEOUT=120000

# ─── Cloud LLM (alternative to Ollama) ───────────────────────────────────────
# To use OpenAI instead:
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
